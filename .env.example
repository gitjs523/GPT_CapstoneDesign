# Local environment values loaded by Spring from .env
# Host-run Spring can use localhost here.
# Local Docker Compose overrides POSTGRES_HOST to `postgres`.
# EC2 container deployment must replace POSTGRES_HOST=localhost with the actual RDS endpoint.

# For EC2 deployment, do not keep `localhost` here. Use the RDS endpoint instead.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=your-db-name
POSTGRES_USER=your-db-user
POSTGRES_PASSWORD=your-db-password

AUTH_JWT_ISSUER=snow
AUTH_ACCESS_TOKEN_SECRET=your-long-access-token-secret
AUTH_ACCESS_TOKEN_EXPIRATION_SECONDS=900
AUTH_REFRESH_TOKEN_EXPIRATION_SECONDS=1209600
AUTH_REFRESH_COOKIE_NAME=snow_refresh
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_SAME_SITE=Lax
AUTH_REFRESH_COOKIE_PATH=/api/auth
AUTH_REFRESH_COOKIE_DOMAIN=

SERVER_PORT=8080

# Ollama (로컬 실행 기준 기본값. Docker Compose는 자동으로 host.docker.internal 을 사용)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3:4b-q4_K_M
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b
